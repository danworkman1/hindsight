{
  "name": "hindsight",
  "version": "0.3.0",
  "description": "Post-implementation code review for Claude Code. CLI-first, with an optional auto-review plugin.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "hindsight": "./dist/index.js",
    "hindsight-surface": "./dist/surface.js"
  },
  "files": [
    "dist/",
    ".claude-plugin/",
    "hooks/",
    "bin/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node index.js",
    "test": "node --test",
    "build": "esbuild index.js surface.js --bundle --platform=node --format=esm --outdir=dist && chmod +x dist/index.js dist/surface.js",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude",
    "claude-code",
    "code-review",
    "claude-code-plugin",
    "post-commit",
    "anthropic",
    "agent"
  ],
  "author": "Daniel Workman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danworkman1/hindsight.git"
  },
  "bugs": {
    "url": "https://github.com/danworkman1/hindsight/issues"
  },
  "homepage": "https://github.com/danworkman1/hindsight#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
